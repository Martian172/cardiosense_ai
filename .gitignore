# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
wheels/
pip-wheel-metadata/
share/python-wheels/
.eggs/
MANIFEST

# Virtual environments
.venv/
venv/
env/
ENV/
env.bak/
venv.bak/
.python-version

# ── Secrets & Environment ─────────────────────────────────────────────────────
.env
*.env
!.env.example
!backend/.env.example
!frontend/.env.example

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.db-journal
*.sqlite
*.sqlite3

# ── ML Model Weights ──────────────────────────────────────────────────────────
*.pt
*.pth
*.onnx
*.pkl
*.pickle
models/
chroma_db/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/

# ── Node / Frontend ───────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/build/
.npm
.yarn/
.pnp.*
*.tsbuildinfo

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Testing & Coverage ────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
coverage.xml
*.cover
.hypothesis/

# ── Docker ────────────────────────────────────────────────────────────────────
.docker/

# ── Alembic ───────────────────────────────────────────────────────────────────
# Keep migrations, ignore generated files
alembic/versions/__pycache__/

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

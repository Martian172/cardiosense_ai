SECRET_KEY=your-super-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
DATABASE_URL=sqlite+aiosqlite:///./cardiosense.db

# Google Gemini API key — get yours free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-1.5-flash

MODEL_PATH=app/ml/ecg_autoencoder.pt
ANOMALY_THRESHOLD=0.05
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
DEBUG=false
